# MODE: monitor | paper | live
BOT_MODE=monitor
ALLOW_MAINNET_LIVE=false

# EXCHANGES — mainnet only
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_BINGX=true
ENABLE_BITGET=true
ENABLE_OKX=true
ENABLE_GATE=true
ENABLE_MEXC=true
ENABLE_KUCOIN=true
ENABLE_HTX=true

# Public REST base URLs
BINANCE_BASE_URL=https://fapi.binance.com
BYBIT_BASE_URL=https://api.bybit.com
BINGX_BASE_URL=https://open-api.bingx.com
BITGET_BASE_URL=https://api.bitget.com
OKX_BASE_URL=https://www.okx.com
GATE_BASE_URL=https://api.gateio.ws
MEXC_BASE_URL=https://contract.mexc.com
KUCOIN_BASE_URL=https://api-futures.kucoin.com
HTX_BASE_URL=https://api.hbdm.com

# API keys — keep real .env private, never commit it
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINGX_API_KEY=
BINGX_API_SECRET=
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
GATE_API_KEY=
GATE_API_SECRET=
MEXC_API_KEY=
MEXC_API_SECRET=
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
HTX_API_KEY=
HTX_API_SECRET=

# STRATEGY
ONLY_POSITIVE_FUNDING=true
MIN_FUNDING_RATE_PERCENT=0.80
MIN_24H_VOLUME_USDT=500000
USE_MAX_VOLUME_FILTER=false
MAX_24H_VOLUME_USDT=50000000
USE_SPREAD_FILTER=false
MAX_SPREAD_PERCENT=0.30

# ENTRY / EXIT
ENTRY_BEFORE_FUNDING_SEC=5
ENTRY_OFFSET_PERCENT=0.20
TAKE_FUNDING_MOVE_PERCENT=95
SCENARIO_2_EXTRA_TP_PERCENT=0.30
SCENARIO_3_GRID_FROM_FAIR_PERCENT=0.50
SCENARIO_3_ONE_SHOT=true

# POSITION / RISK
POSITION_SIZE_MODE=fixed
USDT_PER_TRADE=10
POSITION_PERCENT_OF_BALANCE=50
LEVERAGE=2
MARGIN_MODE=isolated
MAX_ACTIVE_TRADES_PER_EXCHANGE=1
AUTO_SCALE_TRADES_BY_BALANCE=true

# ALERTS
PRE_FUNDING_WARNING_MINUTES=5
STUCK_POSITION_ALERT_INTERVAL_SEC=30
SCAN_INTERVAL_SEC=15
TIME_SYNC_INTERVAL_SEC=10
MAX_ALLOWED_TIME_OFFSET_MS=500

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DASHBOARD_PUBLIC_URL=http://localhost:8095

# DASHBOARD
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8095

# DATABASE placeholder; portable archive currently uses memory store fallback
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=funding_bot
POSTGRES_PASSWORD=funding_bot
POSTGRES_DB=funding_bot

# LOGGING
LOG_LEVEL=info
